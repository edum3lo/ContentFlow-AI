# ---- Supabase ----
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- OpenAI ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# (Opcional) Modelos por tarefa. Se não definir, usa os padrões abaixo.
# Extração (OCR/Vision de PDFs e imagens) — qualidade importa, padrão forte:
OPENAI_EXTRACTION_MODEL=gpt-4o
# Geração de texto (legenda/hashtags/roteiro) — mais perdoável, padrão barato:
OPENAI_GENERATION_MODEL=gpt-4o-mini

# (Opcional) Modelo de imagem por IA (template "IA ✨"). Padrão dall-e-3;
# use gpt-image-1 se a organização da OpenAI estiver verificada.
OPENAI_IMAGE_MODEL=dall-e-3

# ---- Placid (template "Meu design") ----
# https://placid.app → Settings → API Tokens
PLACID_API_TOKEN=
# UUID dos templates que você desenhou no Placid (1 por formato).
# Placid → abra o template → o UUID fica na URL / nos detalhes.
PLACID_TEMPLATE_FEED=
PLACID_TEMPLATE_STORY=
# IMPORTANTE: no seu template do Placid, nomeie as camadas dinâmicas assim
# (são os nomes que o sistema preenche):
#   title          (texto)  → gancho/título
#   product_name   (texto)  → nome do produto
#   price          (texto)  → preço já formatado (ex: R$ 1.572,90)
#   cta            (texto)  → chamada (ex: Chame no WhatsApp)
#   brand          (texto)  → nome da marca
#   product_image  (imagem) → foto do produto (sem fundo)
#   logo           (imagem) → logo da marca
