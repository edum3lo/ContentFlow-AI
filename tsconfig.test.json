{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "node_modules/.cache/tests-build"
  },
  "include": [
    "src/lib/auth-redirect.ts",
    "src/lib/upload-validation.ts",
    "src/lib/video-script.ts",
    "src/lib/calendar.ts",
    "tests/**/*.ts"
  ]
}
